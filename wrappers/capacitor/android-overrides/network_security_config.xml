<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext (plain HTTP) traffic so the reader can reach a home Lyceum
  server on the LAN (LYCM-300). Android blocks cleartext by default; without
  this, API calls and cover images to an http:// server silently fail.

  After `npm run add:android`, copy this file to
    android/app/src/main/res/xml/network_security_config.xml
  and reference it from android/app/src/main/AndroidManifest.xml on the
  <application> element:
    android:networkSecurityConfig="@xml/network_security_config"
    android:usesCleartextTraffic="true"

  Tighten <domain> to your server's address for a release build; the wildcard
  base-config below is convenient for sideloaded debug APKs on a trusted LAN.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
