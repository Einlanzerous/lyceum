# Copy to .env and fill in the lyceum_user password (from
# ~/construct-server/.env LYCEUM_DB_PASSWORD). Connects to the shared
# construct-server Postgres 16 on 127.0.0.1:5432.
DATABASE_URL=postgres://lyceum_user:CHANGE_ME@localhost:5432/lyceum?sslmode=disable
TEST_DATABASE_URL=postgres://lyceum_user:CHANGE_ME@localhost:5432/lyceum_test?sslmode=disable
LYCEUM_ADDR=:8080
LYCEUM_DATA_DIR=data/blobs

# --- Cross-platform wrappers (Phase 3, LYCM-300) ---

# Extra CORS origins allowed to call this server. The native shells (Wails
# desktop, Capacitor Android) load the SPA from their own origins
# (http://wails.localhost, http://localhost, ...) and call the backend
# cross-origin; those built-in native origins are ALWAYS allowed, so the
# wrappers work with this left empty. Add entries (comma-separated) only to
# allow other origins — e.g. a second web deployment — or set to "*" to allow
# any. The same-origin web build needs nothing here.
#   LYCEUM_CORS_ORIGINS=https://reader.example.com,http://192.168.1.10:8080
LYCEUM_CORS_ORIGINS=

# --- Ecosystem & Agent Integration (Phase 4, LYCM-400) ---

# Bearer tokens guarding the /eidolon/* hooks and the send-to-kindle routes
# (LYCM-405). Comma-separated entries of the form  token=scope|scope  with
# scopes drawn from: eidolon:read, delivery:send. Leave empty to keep the
# integration surface closed (every protected request 401s).
# Example:
#   LYCEUM_API_TOKENS=eidolon-localdev=eidolon:read,kindle-bot=delivery:send
LYCEUM_API_TOKENS=

# "Send to Kindle" SMTP relay (LYCM-401/402). Delivery is disabled unless both
# LYCEUM_SMTP_HOST and LYCEUM_SMTP_FROM are set. TLS is one of: starttls
# (default, port 587), implicit (port 465), none (local capture only).
LYCEUM_SMTP_HOST=
LYCEUM_SMTP_PORT=587
LYCEUM_SMTP_USERNAME=
LYCEUM_SMTP_PASSWORD=
LYCEUM_SMTP_FROM=
LYCEUM_SMTP_TLS=starttls

# Default Kindle recipient and whether every uploaded book is auto-delivered.
LYCEUM_KINDLE_ADDR=
LYCEUM_KINDLE_AUTO_SEND=false

# --- Acquisition: folder ingest (LYCM-601) ---

# Watch a directory recursively and ingest new EPUBs through the same path as
# /upload (validate -> SHA-256 dedup -> store -> stamp ISBN onto inventory).
# Point this at the acquisition stack's book library
# (~/construct-server/services/argosy-acquisition imports to /data/media/books).
# Leave empty to disable folder ingest. INTERVAL is the poll period in seconds.
LYCEUM_BOOKS_WATCH_DIR=
LYCEUM_BOOKS_WATCH_INTERVAL=15
