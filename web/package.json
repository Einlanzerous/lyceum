{
  "name": "lyceum-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Lyceum web reader — Vue 3 + epub.js client for the Phase 1 Go backend.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:native": "vue-tsc --noEmit && vite build --mode native",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/archivo": "^5.2.8",
    "epubjs": "^0.3.93",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.3",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.0"
  }
}
