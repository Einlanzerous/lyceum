# Binaries
/bin/
# Anchored so it only ignores the root-built ./lyceum binary, NOT the
# cmd/lyceum/ package directory (an unanchored `lyceum` ignored the entrypoint).
/lyceum
*.exe

# Local data / blob storage
/data/

# Sample books for local testing (not redistributable)
/example_docs/

# Web (see web/.gitignore for node_modules / dist / test artifacts; the
# placeholder web/dist/.gitkeep is kept so //go:embed in web/embed.go compiles)

# Native wrappers (LYCM-300)
node_modules/
# Wails: built .exe and the SPA bundle copied in from web/dist (keep .gitkeep).
build/bin/
wrappers/wails/frontend/dist/*
!wrappers/wails/frontend/dist/.gitkeep
# Wails NSIS installer: project.nsi IS tracked (customizable), but wails_tools.nsh
# is regenerated by every `-nsis` build and tmp/ holds the downloaded WebView2
# bootstrapper — both are build output.
wrappers/wails/build/windows/installer/wails_tools.nsh
wrappers/wails/build/windows/installer/tmp/

# Env
.env
